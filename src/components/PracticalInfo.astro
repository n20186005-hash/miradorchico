---
import type { Lang } from '../i18n/utils';
import { practical } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const _ = (s: any) => typeof s === 'string' ? s : (s[lang] || s.pt || '');
const isTips = (c: any) => c.tips;
---
<section id="practical" class="max-w-7xl mx-auto px-6 py-24 md:py-32">
  <div class="text-xs uppercase tracking-[0.25em] text-[color:var(--color-emerald)]">03 — {_(practical.sectionNum)}</div>
  <h2 class="font-display text-4xl md:text-6xl mt-4 mb-14 max-w-3xl" set:html={_(practical.heading)} />
  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
    {practical.cards.map((card, i) => (
      <div class={`rounded-3xl bg-white border border-black/5 p-6 ${i === 3 ? 'bg-[color:var(--color-sun)]/20 border-[color:var(--color-sun)]/40' : ''}`}>
        {card.icon && <div class="text-3xl">{card.icon}</div>}
        <div class="text-xs uppercase tracking-widest text-[color:var(--color-emerald)] mt-4">{_(card.label)}</div>
        {card.value && <div class="font-display text-2xl mt-1">{_(card.value)}</div>}
        {isTips(card)
          ? (
            <div class="mt-4 space-y-2.5">
              {card.tips.map((tip: any) => (
                <div class="flex gap-3">
                  <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[color:var(--color-emerald)] flex-shrink-0"></span>
                  <div class="text-sm text-[color:var(--color-ink)]/90 leading-relaxed" set:html={_(tip)} />
                </div>
              ))}
            </div>
          )
          : <p class="text-sm text-[color:var(--color-moss)]/80 mt-2">{_(card.desc)}</p>}
      </div>
    ))}
  </div>
</section>
