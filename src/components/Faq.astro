---
import type { Lang } from '../i18n/utils';
import { faq } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const _ = (s: any) => typeof s === 'string' ? s : (s[lang] || s.pt || '');
---

<section id="faq" class="max-w-4xl mx-auto px-6 py-24 md:py-32">
  <!-- Section header -->
  <div class="text-xs uppercase tracking-[0.25em] text-[color:var(--color-emerald)] text-center">
    09 — {_(faq.sectionNum)}
  </div>
  <h2 class="font-display text-4xl md:text-6xl mt-4 text-center mb-8" set:html={_(faq.heading)} />

  <!-- Authority disclaimer -->
  <div class="mb-14 p-5 rounded-xl bg-[color:var(--color-mist)] border border-black/10">
    <div class="flex gap-3 items-start">
      <span class="text-lg flex-shrink-0 mt-0.5">📋</span>
      <p class="text-sm text-[color:var(--color-moss)] leading-relaxed italic">
        {_(faq.disclaimer)}
      </p>
    </div>
  </div>

  <!-- FAQ accordion -->
  <div class="space-y-4">
    {faq.items.map((item, i) => (
      <details class="group rounded-2xl border border-black/10 bg-white overflow-hidden transition-shadow duration-300 hover:shadow-md">
        <summary class="cursor-pointer flex justify-between items-center gap-4 list-none p-6 md:p-8">
          <div class="flex items-start gap-4">
            <span class="font-display text-2xl text-[color:var(--color-emerald)] opacity-40 flex-shrink-0">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="font-display text-lg md:text-xl leading-snug">{_(item.q)}</span>
          </div>
          <span class="faq-plus text-2xl text-[color:var(--color-emerald)] flex-shrink-0 transition-transform duration-300 group-open:rotate-45">+</span>
        </summary>
        <div class="px-6 md:px-8 pb-6 md:pb-8">
          <div class="pl-11 md:pl-14">
            <div class="w-12 h-px bg-[color:var(--color-emerald)] opacity-30 mb-4"></div>
            <p class="text-[color:var(--color-moss)] leading-relaxed text-sm md:text-base" set:html={_(item.a)} />
          </div>
        </div>
      </details>
    ))}
  </div>
</section>
