---
import type { Lang } from '../i18n/utils';
import { climate } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const _ = (s: any) => typeof s === 'string' ? s : (s[lang] || s.pt || '');
const LAT = 16.7519, LNG = -22.9375, TZ = 'Atlantic/Cape_Verde';
const LOCALE = lang === 'zh' ? 'zh-CN' : (lang === 'pt' || lang === 'cri') ? 'pt-PT' : 'en-US';
const labels = {
  rising: _(climate.rising), falling: _(climate.falling),
  nextHigh: _(climate.nextHigh), nextLow: _(climate.nextLow),
  loading: _(climate.loading), error: _(climate.error),
};
---
<section class="bg-[color:var(--color-mist)] py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-xs uppercase tracking-[0.25em] text-[color:var(--color-emerald)]">{_(climate.sectionNum)}</div>
      <h2 class="font-display text-4xl md:text-6xl mt-4" set:html={_(climate.heading)} />
      <p class="mt-6 text-[color:var(--color-moss)]/80">{_(climate.subtitle)}</p>
    </div>
    <div class="mt-14 grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
      <div class="rounded-3xl bg-white p-8 border border-black/5 text-center">
        <div class="text-xs uppercase tracking-widest text-[color:var(--color-emerald)]">{_(climate.sunsetLabel)}</div>
        <div class="num-display text-5xl mt-3" id="ct-sun">—</div>
      </div>
      <div class="rounded-3xl bg-white p-8 border border-black/5 text-center">
        <div class="text-xs uppercase tracking-widest text-[color:var(--color-emerald)]">{_(climate.tideLabel)}</div>
        <div class="num-display text-5xl mt-3" id="ct-tide">—</div>
        <div class="text-sm text-[color:var(--color-moss)]/70 mt-2" id="ct-tide-sub">—</div>
      </div>
    </div>
    <div class="mt-6 max-w-3xl mx-auto rounded-3xl bg-white p-8 border border-black/5">
      <div class="text-xs uppercase tracking-widest text-[color:var(--color-emerald)]">{_(climate.timelineLabel)}</div>
      <p class="mt-2 text-sm text-[color:var(--color-moss)]/70">{_(climate.timelineDesc)}</p>
      <div class="mt-6 grid md:grid-cols-[1fr,220px] gap-8 items-center">
        <div>
          <div class="flex items-center justify-between gap-4 text-xs text-[color:var(--color-moss)]/70 flex-wrap">
            <span>{_(climate.timelineTime)}: <span class="num-display" id="ct-time">12:00</span></span>
            <span class="text-[color:var(--color-emerald)]">{_(climate.timelineBest)}</span>
          </div>
          <input id="ct-slider" type="range" min="8" max="16" step="0.25" value="12" class="w-full mt-4 accent-[color:var(--color-emerald)]" />
          <div class="mt-4 h-2 rounded-full bg-[color:var(--color-mist)] overflow-hidden">
            <div id="ct-fill" class="h-full bg-[color:var(--color-emerald)]" style="width:50%"></div>
          </div>
          <div class="mt-3 text-xs text-[color:var(--color-moss)]/70">{_(climate.timelineGlow)}: <span class="num-display" id="ct-glow">100%</span></div>
        </div>
        <div class="flex items-center justify-center">
          <div id="ct-eye" class="w-44 h-44 rounded-full border border-black/10 overflow-hidden"></div>
        </div>
      </div>
    </div>
    <div class="mt-6 text-center text-xs text-[color:var(--color-moss)]/50">{_(climate.source)}</div>
  </div>
</section>

<script define:vars={{ LAT, LNG, TZ, LOCALE, labels }}>
  (async () => {
    const sunEl = document.getElementById('ct-sun');
    const tideEl = document.getElementById('ct-tide');
    const subEl = document.getElementById('ct-tide-sub');
    const fmt = (iso) => new Date(iso).toLocaleTimeString(LOCALE, { timeZone: TZ, hour: '2-digit', minute: '2-digit', hour12: false });
    try {
      const [sunRes, tideRes] = await Promise.all([
        fetch(`https://api.sunrise-sunset.org/json?lat=${LAT}&lng=${LNG}&formatted=0`),
        fetch(`https://marine-api.open-meteo.com/v1/marine?latitude=${LAT}&longitude=${LNG}&hourly=sea_level_height_msl&timezone=${encodeURIComponent(TZ)}`),
      ]);
      const sun = await sunRes.json();
      const tide = await tideRes.json();
      const sunset = new Date(sun.results.sunset).toLocaleTimeString(LOCALE, { timeZone: TZ, hour: '2-digit', minute: '2-digit', hour12: false });
      const times = tide.hourly.time, vals = tide.hourly.sea_level_height_msl;
      const now = Date.now();
      let idx = 0, best = Infinity;
      for (let i = 0; i < times.length; i++) {
        const d = Math.abs(new Date(times[i]).getTime() - now);
        if (d < best) { best = d; idx = i; }
      }
      const cur = vals[idx];
      const rising = vals[idx + 1] > cur;
      let hi = null, lo = null;
      for (let i = Math.max(1, idx); i < times.length - 1; i++) {
        if (hi === null && vals[i] >= vals[i - 1] && vals[i] > vals[i + 1]) hi = fmt(times[i]);
        if (lo === null && vals[i] <= vals[i - 1] && vals[i] < vals[i + 1]) lo = fmt(times[i]);
        if (hi !== null && lo !== null) break;
      }
      sunEl.textContent = sunset;
      tideEl.textContent = cur.toFixed(2) + ' m';
      subEl.textContent = `${rising ? labels.rising : labels.falling} · ${labels.nextHigh} ${hi || '—'} · ${labels.nextLow} ${lo || '—'}`;
    } catch (e) {
      sunEl.textContent = labels.error;
      tideEl.textContent = '';
      subEl.textContent = '';
    }
  })();

  (() => {
    const slider = document.getElementById('ct-slider');
    const timeEl = document.getElementById('ct-time');
    const glowEl = document.getElementById('ct-glow');
    const fillEl = document.getElementById('ct-fill');
    const eyeEl = document.getElementById('ct-eye');
    if (!slider || !timeEl || !glowEl || !fillEl || !eyeEl) return;
    const clamp01 = (v) => Math.max(0, Math.min(1, v));
    const fmtHM = (h) => {
      const hh = Math.floor(h);
      const mm = Math.round((h - hh) * 60);
      return String(hh).padStart(2, '0') + ':' + String(mm).padStart(2, '0');
    };
    const intensityAt = (h) => {
      const d = Math.abs(h - 12) / 4;
      return clamp01(Math.cos(Math.min(1, d) * Math.PI / 2));
    };
    const render = () => {
      const h = parseFloat(slider.value);
      const x = (h - 8) / 8;
      const intensity = intensityAt(h);
      timeEl.textContent = fmtHM(h);
      glowEl.textContent = Math.round(intensity * 100) + '%';
      fillEl.style.width = Math.round(x * 100) + '%';
      const blueA = 0.18 + intensity * 0.62;
      const sunA = 0.08 + intensity * 0.16;
      eyeEl.style.backgroundImage = `radial-gradient(circle at 35% 30%, rgba(232,177,75,${sunA}) 0%, rgba(47,107,78,0.10) 35%, rgba(0,120,255,${blueA}) 70%, rgba(237,243,239,1) 100%)`;
      eyeEl.style.boxShadow = `inset 0 0 0 10px rgba(11,31,26,0.03), 0 18px 40px -26px rgba(11,31,26,0.35)`;
    };
    slider.addEventListener('input', render);
    render();
  })();
</script>
