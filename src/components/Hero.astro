---
import type { Lang } from '../i18n/utils';
import { hero } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const _ = (s: any) => typeof s === 'string' ? s : (s[lang] || s.pt || '');
const gmapsUrl = 'https://maps.app.goo.gl/7mpNnhQ9kcnKLj4r9';
---
<section id="top" class="hero-bg relative min-h-[100vh] flex items-end pt-24" style="background-image: linear-gradient(180deg, rgba(11,31,26,.15) 0%, rgba(11,31,26,.55) 55%, rgba(11,31,26,.85) 100%), url('/gallery/punto-panoramico-circuito-chico-1.jpg')">
  <div class="rain absolute inset-0"></div>
  <div class="relative max-w-7xl mx-auto px-6 pb-16 w-full text-white">
    <div class="flex items-center gap-3 mb-6">
      <span class="chip text-white/90 text-xs px-3 py-1 rounded-full bg-white/10">{_(hero.chip1)}</span>
      <span class="chip text-white/90 text-xs px-3 py-1 rounded-full bg-white/10">{_(hero.chip2)}</span>
      <span class="chip text-white/90 text-xs px-3 py-1 rounded-full bg-white/10">{_(hero.chip3)}</span>
    </div>
    <h1 class="font-display font-semibold leading-[0.95] tracking-tight text-5xl md:text-7xl lg:text-8xl max-w-5xl" set:html={_(hero.title)} />
    <p class="mt-6 max-w-2xl text-white/85 text-lg md:text-xl leading-relaxed">{_(hero.subtitle)}</p>
    <a href={gmapsUrl} target="_blank" rel="noopener noreferrer" class="mt-8 inline-flex items-center gap-2 bg-white/15 hover:bg-white/25 backdrop-blur border border-white/20 rounded-full px-5 py-3 text-sm font-medium transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
      {_(hero.viewMap)}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
    <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl">
      <div><div class="num-display text-4xl md:text-5xl">4.3</div><div class="text-xs uppercase tracking-widest text-white/70">{_(hero.statLength)}</div></div>
      <div><div class="num-display text-4xl md:text-5xl">4,750</div><div class="text-xs uppercase tracking-widest text-white/70">{_(hero.statReviews)}</div></div>
      <div><div class="num-display text-4xl md:text-5xl">09:00–18:00</div><div class="text-xs uppercase tracking-widest text-white/70">{_(hero.statFalls)}</div></div>
      <div><div class="num-display text-4xl md:text-5xl">Sal</div><div class="text-xs uppercase tracking-widest text-white/70">{_(hero.statFlow)}</div></div>
    </div>
  </div>
</section>
