---
import type { Lang } from '../i18n/utils';
import { leaveNoTrace } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const _ = (s: any) => typeof s === 'string' ? s : (s[lang] || s.pt || '');
---

<section id="leave-no-trace" class="max-w-5xl mx-auto px-6 py-24 md:py-32">
  <!-- Section header -->
  <div class="text-xs uppercase tracking-[0.25em] text-[color:var(--color-emerald)] text-center">
    {_(leaveNoTrace.sectionNum)}
  </div>
  <h2 class="font-display text-4xl md:text-6xl mt-4 text-center mb-8" set:html={_(leaveNoTrace.heading)} />

  <!-- Subtitle -->
  <p class="text-lg leading-relaxed text-[color:var(--color-moss)] text-center max-w-3xl mx-auto mb-16">
    {_(leaveNoTrace.subtitle)}
  </p>

  <!-- Rules grid -->
  <div class="grid md:grid-cols-2 gap-5 mb-16">
    {leaveNoTrace.rules.map((rule) => (
      <div class="rounded-2xl border border-black/10 bg-white p-6 md:p-8 flex gap-5 items-start card-hover">
        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-[color:var(--color-mist)] flex items-center justify-center text-2xl">
          {rule.icon}
        </div>
        <div>
          <h3 class="font-display text-lg md:text-xl mb-2 text-[color:var(--color-ink)]">
            {_(rule.title)}
          </h3>
          <p class="text-sm leading-relaxed text-[color:var(--color-moss)]">
            {_(rule.desc)}
          </p>
        </div>
      </div>
    ))}
  </div>

  <!-- Closing blockquote -->
  <div class="text-center border-t border-black/10 pt-12">
    <blockquote class="font-display text-xl md:text-2xl leading-relaxed text-[color:var(--color-moss)] italic max-w-2xl mx-auto" set:html={_(leaveNoTrace.closing)} />
  </div>
</section>
