---
import type { Lang } from '../i18n/utils';
import { footer, partners } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const _ = (s: any) => typeof s === 'string' ? s : (s[lang] || s.es || s.pt || '');
---
<footer class="bg-[color:var(--color-ink)] text-[color:var(--color-cream)]">
  <div class="max-w-7xl mx-auto px-6 py-20 grid md:grid-cols-12 gap-10">
    <div class="md:col-span-6">
      <h2 class="font-display text-4xl md:text-5xl leading-tight" set:html={_(footer.cta)} />
      <p class="mt-6 text-white/70 max-w-md">{_(footer.address)}</p>
    </div>
    <div class="md:col-span-3">
      <div class="text-xs uppercase tracking-widest text-[color:var(--color-sun)] mb-4">Location</div>
      <div class="space-y-1 text-white/80">
        <div>Plus Code · WFHH+74</div><div>San Carlos de Bariloche</div><div>Argentina</div>
        <div class="mt-4"><a href="https://maps.app.goo.gl/xxMwnuJaomSDMuVw7" target="_blank" rel="noopener" class="link-underline text-[color:var(--color-sun)]">Google Maps →</a></div>
      </div>
    </div>
    <div class="md:col-span-3">
      <div class="text-xs uppercase tracking-widest text-[color:var(--color-sun)] mb-4">Rating</div>
      <div class="num-display text-5xl">4.9</div>
      <div class="text-white/60 text-sm">15,000+</div>
    </div>
  </div>
  <!-- Disclaimer + Legal Links -->
  <div class="max-w-7xl mx-auto px-6 pb-10">
    <p class="text-white/50 text-sm leading-relaxed max-w-3xl">{_(footer.disclaimer)}</p>
    <div class="flex flex-wrap gap-x-6 gap-y-2 mt-4 text-sm text-white/60">
      <a href={`/${lang}/privacy`} class="link-underline">{_(footer.privacy)}</a>
      <a href={`/${lang}/terms`} class="link-underline">{_(footer.terms)}</a>
      <a href={`/${lang}/cookies`} class="link-underline">{_(footer.cookies)}</a>
      <a href={`/${lang}/#leave-no-trace`} class="link-underline">{_(footer.leaveNoTrace)}</a>
    </div>
  </div>
  <!-- Partners -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 py-12">
      <h3 class="text-xs uppercase tracking-widest text-[color:var(--color-sun)] mb-8 text-center">{_(partners.heading)}</h3>
      <p class="text-white/55 text-sm text-center max-w-3xl mx-auto">{_(footer.sourcesNote)}</p>
      <div class="grid md:grid-cols-3 gap-4 mt-8">
        {partners.items.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            title={_(p.attr)}
            class="rounded-2xl border border-white/10 px-5 py-4 transition-colors duration-300 hover:bg-white/5"
          >
            <div class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-sun)]/80">{_(p.note)}</div>
            <div class="mt-3 text-sm leading-relaxed text-white/75">{_(p.name)}</div>
          </a>
        ))}
      </div>
    </div>
  </div>
  <div class="border-t border-white/10 py-6 text-center text-xs text-white/40">
    {_(footer.copyright)}
  </div>
</footer>
