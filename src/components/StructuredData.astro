---
import type { Lang } from '../i18n/utils';
interface Props { lang: Lang; }
const { lang } = Astro.props;

const descMap: Record<Lang, string> = {
  zh: '佛得角萨尔岛帕尔梅拉附近的蓝眼岩洞（Olho Azul/Blue Eye），玄武岩海岸裂隙与海蚀洞形成的潮池系统。正午阳光透入海水，在洞底折射出深邃蓝光。营业时间 09:00–18:00。',
  en: 'Buracona (Olho Azul / Blue Eye) near Palmeira, Sal, Cape Verde — a basalt sea-cave and tide-pool system where midday sunlight refracts through seawater into an intense blue glow. Open 09:00–18:00.',
  cri: 'Buracona (Olho Azul / Blue Eye) perto de Palmeira, Sal, Cabo Verde — sistema di gruta di mar i poça di maré na basalto, undi luz di mei-dia ta refrata na água i ta da un azul forte. Abertu 09:00–18:00.',
  pt: 'Buracona (Olho Azul / Blue Eye) perto de Palmeira, Sal, Cabo Verde — um sistema de gruta marinha e poça de maré em basalto onde a luz do meio-dia se refrata na água e cria um azul intenso. Aberto 09:00–18:00.',
};

const tourist = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'TouristAttraction',
  name: 'Buracona - Blue Eye Cave', description: descMap[lang],
  image: new URL('/gallery/punto-panoramico-circuito-chico-1.jpg', Astro.site).href,
  address: { '@type': 'PostalAddress', streetAddress: '', addressLocality: 'Palmeira', addressRegion: 'Sal', postalCode: '', addressCountry: 'CV' },
  geo: { '@type': 'GeoCoordinates', latitude: 16.7519, longitude: -22.9375 },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.3', reviewCount: '4750' },
  openingHours: 'Mo-Su 09:00-18:00',
});

const faqData = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Is there an entrance fee?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Buracona is managed by a local community association; entry is paid and includes a local guide.' } },
    { '@type': 'Question', name: 'How do I get there?', acceptedAnswer: { '@type': 'Answer', text: 'From Santa Maria (~30 km) by taxi / aluguer or rental car; from Amílcar Cabral airport in Espargos (~20 km) by taxi or hired transfer.' } },
    { '@type': 'Question', name: 'When is the best time to visit?', acceptedAnswer: { '@type': 'Answer', text: 'Around midday for the famous Blue Eye glow, and late afternoon for the "Last Breath of the Sun" (Último Suspiro do Sol) sunset viewpoint.' } },
    { '@type': 'Question', name: 'Is it safe to visit?', acceptedAnswer: { '@type': 'Answer', text: 'The ground is sharp, heat-holding basalt — wear sturdy closed shoes, bring water and sun protection, and stay with your guide at all times.' } },
  ],
});
---
<Fragment set:html={'<script type="application/ld+json">' + tourist + '</script><script type="application/ld+json">' + faqData + '</script>'} />
