---
import type { Lang } from '../i18n/utils';
interface Props { lang: Lang; }
const { lang } = Astro.props;

const descMap: Record<Lang, string> = {
  zh: 'Punto Panorámico（巴里洛切小环线 RP77）是一处免费、24 小时开放的公共观景台，俯瞰纳韦尔瓦皮湖、劳劳半岛与特罗纳多峰，位于纳韦尔瓦皮国家公园内。',
  en: 'Punto Panorámico on the Circuito Chico (RP77) in Bariloche — a free, 24-hour public viewpoint overlooking Nahuel Huapi Lake, the Llao Llao peninsula and Cerro Tronador, inside Nahuel Huapi National Park.',
  es: 'Punto Panorámico en el Circuito Chico (RP77) de Bariloche — un mirador público libre y abierto las 24 h, con vistas al lago Nahuel Huapi, la península de Llao Llao y el Cerro Tronador, dentro del Parque Nacional Nahuel Huapi.',
};

const tourist = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'TouristAttraction',
  name: 'Punto Panorámico - Bariloche Viewpoint', description: descMap[lang],
  image: new URL('/gallery/punto-panoramico-circuito-chico-1.jpg', Astro.site).href,
  address: { '@type': 'PostalAddress', streetAddress: 'Circuito Chico (RP77)', addressLocality: 'San Carlos de Bariloche', addressRegion: 'Río Negro', postalCode: '', addressCountry: 'AR' },
  geo: { '@type': 'GeoCoordinates', latitude: -41.1233, longitude: -71.3472 },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '15000' },
  openingHours: 'Mo-Su 00:00-24:00',
});

const faqData = JSON.stringify({
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Is there an entrance fee?', acceptedAnswer: { '@type': 'Answer', text: 'No. Punto Panorámico is a free public viewpoint, open 24 hours and unattended. Daylight and dusk offer the best views.' } },
    { '@type': 'Question', name: 'How do I get there?', acceptedAnswer: { '@type': 'Answer', text: 'From downtown Bariloche, drive, take a taxi/remis, cycle the paved RP77 Circuito Chico, or ride Línea 20 and walk from a nearby stop. From BRC airport, most visitors first reach town and then continue by rental car, taxi/remis, tour, or a transfer to Línea 20.' } },
    { '@type': 'Question', name: 'When is the best time to visit?', acceptedAnswer: { '@type': 'Answer', text: 'On a clear day for the blue lake and snow peaks; about 60 minutes before sunset Cerro Tronador glows gold-red — the golden window for photography.' } },
    { '@type': 'Question', name: 'Is it safe to visit?', acceptedAnswer: { '@type': 'Answer', text: 'The terrace edge has no railing — keep clear of the drop and watch children. The Andean westerlies are strong, so dress for wind and cold; there are no facilities nearby.' } },
  ],
});
---
<Fragment set:html={'<script type="application/ld+json">' + tourist + '</script><script type="application/ld+json">' + faqData + '</script>'} />
