---
import type { Lang } from '../i18n/utils';
import { transport } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const _ = (s: any) => typeof s === 'string' ? s : (s[lang] || s.es || s.pt || '');
const renderTransportIcon = (icon: string) => {
  switch (icon) {
    case '🚗':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 16H9m10 0h1a1 1 0 0 0 1-1v-3.5a2 2 0 0 0-.6-1.4l-2-2A2 2 0 0 0 17 7.5H7a2 2 0 0 0-1.8 1.2L4 11.5H3a1 1 0 0 0-1 1V15a1 1 0 0 0 1 1h1"/><circle cx="7" cy="16" r="2"/><circle cx="17" cy="16" r="2"/></svg>';
    case 'Air':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 16l20-5-20-5 5 5-5 5z"/><path d="M7 11h8"/><path d="M7 6l3 5"/><path d="M7 16l3-5"/></svg>';
    case 'Cab':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 16h14"/><path d="M7 16l1.2-5.1A2 2 0 0 1 10.1 9h3.8a2 2 0 0 1 1.9 1.9L17 16"/><path d="M4 13h16"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/><path d="M9 6h6"/></svg>';
    case 'Bus':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3h8a3 3 0 0 1 3 3v9H5V6a3 3 0 0 1 3-3z"/><path d="M5 15v2a2 2 0 0 0 2 2h.5"/><path d="M19 15v2a2 2 0 0 1-2 2h-.5"/><path d="M7 19v2"/><path d="M17 19v2"/><circle cx="8" cy="17" r="1.5"/><circle cx="16" cy="17" r="1.5"/><path d="M8 7h8"/><path d="M7 11h10"/></svg>';
    case '🚲':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="6.5" cy="17.5" r="3.5"/><circle cx="17.5" cy="17.5" r="3.5"/><path d="M10 17.5 8 8h4l2 4h3"/><path d="M14 12 9.5 17.5"/><path d="M8.5 8H6"/></svg>';
    default:
      return icon;
  }
};
---
<section class="bg-[color:var(--color-mist)] py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-12 gap-12 items-start">
      <div class="md:col-span-4">
        <div class="text-xs uppercase tracking-[0.25em] text-[color:var(--color-emerald)]">04 — {_(transport.sectionNum)}</div>
        <h2 class="font-display text-4xl md:text-5xl mt-4 leading-tight" set:html={_(transport.heading)} />
        <p class="mt-6 text-[color:var(--color-moss)]/80">{_(transport.subtitle)}</p>
      </div>
      <div class="md:col-span-8 space-y-4">
        {transport.items.map((item) => (
          <div class="rounded-3xl bg-white p-7 border border-black/5">
            <div class="flex items-start gap-5">
              <div class="shrink-0 text-[color:var(--color-emerald)]" set:html={renderTransportIcon(item.icon)} />
              <div class="flex-1">
                <div class="flex justify-between items-baseline gap-4 flex-wrap"><h3 class="font-display text-2xl">{_(item.title)}</h3><span class="text-[color:var(--color-emerald)] font-medium">{_(item.meta)}</span></div>
                {item.details.length === 1 ? <p class="mt-4 text-[color:var(--color-moss)]" set:html={_(item.details[0].text)} /> : <ul class="mt-4 space-y-3 text-[color:var(--color-moss)]">{item.details.map((d: any) => <li class="flex items-start gap-3"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-[color:var(--color-emerald)]/70 shrink-0"></span><span set:html={_(d.text)} /></li>)}</ul>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
