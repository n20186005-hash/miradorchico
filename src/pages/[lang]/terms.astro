---
import '../../../src/styles/global.css';
import { LANGUAGES, type Lang } from '../../i18n/utils';
import { terms, footer } from '../../i18n/translations';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return LANGUAGES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const _ = (s: any) => typeof s === 'string' ? s : (s[lang] || s.pt || '');
---
<BaseLayout lang={lang} title={_(terms.title)} description={_(terms.title)}>
  <Nav lang={lang} />
  <main class="max-w-3xl mx-auto px-6 pt-24 pb-16">
    <h1 class="font-display text-4xl md:text-5xl mt-10 mb-4">{_(terms.h1)}</h1>
    <p class="text-sm text-[color:var(--color-moss)]/60 mb-10">{_(terms.lastUpdated)}</p>

    <section class="space-y-10 text-[color:var(--color-moss)] leading-relaxed">
      <div>
        <h2 class="font-display text-2xl text-[color:var(--color-ink)] mb-3">{_(terms.h2_acceptance)}</h2>
        <p>{_(terms.p_acceptance)}</p>
      </div>
      <div>
        <h2 class="font-display text-2xl text-[color:var(--color-ink)] mb-3">{_(terms.h2_content)}</h2>
        <p>{_(terms.p_content)}</p>
      </div>
      <div>
        <h2 class="font-display text-2xl text-[color:var(--color-ink)] mb-3">{_(terms.h2_accuracy)}</h2>
        <p>{_(terms.p_accuracy)}</p>
      </div>
      <div>
        <h2 class="font-display text-2xl text-[color:var(--color-ink)] mb-3">{_(terms.h2_ip)}</h2>
        <p>{_(terms.p_ip)}</p>
      </div>
      <div>
        <h2 class="font-display text-2xl text-[color:var(--color-ink)] mb-3">{_(terms.h2_liability)}</h2>
        <p>{_(terms.p_liability)}</p>
      </div>
    </section>

    <div class="mt-16 pt-8 border-t border-black/10">
      <a href={`/${lang}/`} class="link-underline text-[color:var(--color-emerald)]">{_(terms.backLink)}</a>
    </div>
  </main>
  <Footer lang={lang} />
</BaseLayout>
